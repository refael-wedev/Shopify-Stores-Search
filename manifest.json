{
  "manifest_version": 3,
  "name": "Shopify Stores Search",
  "version": "1.4.0",
  "description": "Search Dev, Client transfer, and Collaborations stores in one place on the Shopify Dev Dashboard.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Shopify Stores Search",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "host_permissions": ["https://dev.shopify.com/*"],
  "content_scripts": [
    {
      "matches": ["https://dev.shopify.com/dashboard/*/stores*"],
      "js": ["src/content.js"],
      "css": ["src/overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
